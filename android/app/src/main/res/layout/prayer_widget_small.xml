<?xml version="1.0" encoding="utf-8"?>
<!--
  Small Prayer Widget (2×2)
  Features:
    - Circular progress ring (track + fill arc via RotateDrawable approach)
    - Prayer name centered
    - Time centered in gold
    - "in Xm" countdown label below
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="4dp">

    <!-- Progress Ring Track -->
    <ImageView
        android:id="@+id/widget_ring_track"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="center"
        android:src="@drawable/widget_progress_ring_bg"
        android:scaleType="fitXY" />

    <!-- Progress Ring Fill (rotate to simulate progress; rotated in Java) -->
    <ImageView
        android:id="@+id/widget_ring_progress"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="center"
        android:src="@drawable/widget_progress_ring_fg"
        android:scaleType="fitXY"
        android:rotation="-90" />

    <!-- Center Content -->
    <LinearLayout
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Next Prayer Label -->
        <TextView
            android:id="@+id/widget_label_small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_next_prayer"
            android:textColor="#A7F3D0"
            android:textSize="7sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <!-- Prayer Name -->
        <TextView
            android:id="@+id/widget_prayer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/prayer_maghrib"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <!-- Prayer Time -->
        <TextView
            android:id="@+id/widget_prayer_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_time_default"
            android:textColor="#F59E0B"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Countdown label at very bottom -->
    <TextView
        android:id="@+id/widget_time_remaining"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="6dp"
        android:text="@string/widget_time_remaining_default"
        android:textColor="#6EE7B7"
        android:textSize="8sp"
        android:singleLine="true" />

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
  Medium Prayer Widget (4×2)
  Sections (left → right):
    Left  : App icon area + Location chip + Hijri date
    Center: NEXT PRAYER label → Prayer name (large) → Countdown pill
    Right : All-5-prayers dot row + Prayer time (large gold)
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- ══════════════ LEFT SECTION ══════════════ -->
    <LinearLayout
        android:id="@+id/widget_left_section"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:orientation="vertical"
        android:gravity="start">

        <!-- App name / brand -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نور"
            android:textColor="#A7F3D0"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Hijri Date -->
        <TextView
            android:id="@+id/widget_hijri_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_hijri_default"
            android:textColor="#6EE7B7"
            android:textSize="9sp"
            android:layout_marginTop="2dp" />

        <!-- Location chip -->
        <LinearLayout
            android:id="@+id/widget_location_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/widget_location_chip"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/widget_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_location_default"
                android:textColor="#D1FAE5"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:maxWidth="80dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════ RIGHT SECTION ══════════════ -->
    <LinearLayout
        android:id="@+id/widget_right_section"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true"
        android:orientation="vertical"
        android:gravity="end">

        <!-- Prayer time — large gold -->
        <TextView
            android:id="@+id/widget_prayer_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_time_default"
            android:textColor="#F59E0B"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"/>

        <!-- 5-prayer dot row -->
        <LinearLayout
            android:id="@+id/widget_prayer_dots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/dot_fajr"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/widget_dot_upcoming" />

            <ImageView
                android:id="@+id/dot_dhuhr"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/widget_dot_upcoming" />

            <ImageView
                android:id="@+id/dot_asr"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/widget_dot_upcoming" />

            <ImageView
                android:id="@+id/dot_maghrib"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/widget_dot_active" />

            <ImageView
                android:id="@+id/dot_isha"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/widget_dot_upcoming" />

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════ CENTER SECTION ══════════════ -->
    <LinearLayout
        android:id="@+id/widget_center_section"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_toEndOf="@id/widget_left_section"
        android:layout_toStartOf="@id/widget_right_section"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:orientation="vertical"
        android:gravity="center">

        <!-- "NEXT PRAYER" label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_next_prayer"
            android:textColor="#A7F3D0"
            android:textSize="9sp"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <!-- Prayer Name — headline -->
        <TextView
            android:id="@+id/widget_prayer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/prayer_maghrib"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="1dp" />

        <!-- Countdown pill -->
        <LinearLayout
            android:id="@+id/widget_countdown_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/widget_location_chip"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/widget_time_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_time_remaining_default"
                android:textColor="#D1FAE5"
                android:textSize="10sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Top shimmer line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/widget_row_divider" />

</RelativeLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
  Daily Schedule Widget (4×2)
  Shows all prayer times in a scrollable list with highlighted next prayer.
  Uses ListView + RemoteViewsService for list adapter.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingBottom="4dp"
        android:text="Prayer Times"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <ListView
        android:id="@+id/prayer_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp" />

    <TextView
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Open app to sync prayer times"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>

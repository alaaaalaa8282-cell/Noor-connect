<?xml version="1.0" encoding="utf-8"?>
<!--
  Quran Verse Widget (4×2)
  Shows today's daily Ayah:
    - Arabic text (RTL, large)
    - Reference chip
    - Transliteration (italic, smaller)
    - Tap to open app at Quran page
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/quran_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Top shimmer line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#10B98160"
        android:layout_marginBottom="8dp" />

    <!-- Reference chip (surah:ayah) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_location_chip"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_gravity="start">

        <TextView
            android:id="@+id/widget_quran_ref"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_quran_ref_default"
            android:textColor="#A7F3D0"
            android:textSize="9sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Arabic Verse -->
    <TextView
        android:id="@+id/widget_quran_arabic"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="@string/widget_quran_arabic_default"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:gravity="end|center_vertical"
        android:lineSpacingMultiplier="1.35"
        android:textDirection="rtl"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="4dp" />

    <!-- Transliteration -->
    <TextView
        android:id="@+id/widget_quran_translit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_quran_translit_default"
        android:textColor="#6EE7B7"
        android:textSize="10sp"
        android:textStyle="italic"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="4dp" />

    <!-- Tap hint -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_tap_to_setup"
        android:textColor="#FFFFFF40"
        android:textSize="8sp"
        android:layout_marginTop="4dp"
        android:layout_gravity="end" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
  Large Prayer Widget (4×4)
  Full 5-prayer timetable with:
    - Header: app name + Hijri date + current time clock
    - 5 prayer rows (active row highlighted gold)
    - Bottom: location chip
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_large"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- ══════ HEADER ══════ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp">

        <!-- App brand (Arabic Noor) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="نور كونكت"
            android:textColor="#A7F3D0"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Hijri Date (center) -->
        <TextView
            android:id="@+id/widget_hijri_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/widget_hijri_default"
            android:textColor="#6EE7B7"
            android:textSize="11sp"
            android:gravity="center" />

        <!-- Current clock time (right) -->
        <TextView
            android:id="@+id/widget_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="@string/widget_time_default"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- Top divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FFFFFF20"
        android:layout_marginBottom="6dp" />

    <!-- ══════ PRAYER ROW: FAJR ══════ -->
    <RelativeLayout
        android:id="@+id/row_fajr"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/label_fajr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/prayer_fajr"
            android:textColor="#D1FAE5"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/dot_fajr"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_centerInParent="true"
            android:src="@drawable/widget_dot_upcoming" />

        <TextView
            android:id="@+id/time_fajr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="05:15"
            android:textColor="#F59E0B"
            android:textSize="14sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FFFFFF12" />

    <!-- ══════ PRAYER ROW: DHUHR ══════ -->
    <RelativeLayout
        android:id="@+id/row_dhuhr"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/label_dhuhr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/prayer_dhuhr"
            android:textColor="#D1FAE5"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/dot_dhuhr"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_centerInParent="true"
            android:src="@drawable/widget_dot_upcoming" />

        <TextView
            android:id="@+id/time_dhuhr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="12:30"
            android:textColor="#F59E0B"
            android:textSize="14sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FFFFFF12" />

    <!-- ══════ PRAYER ROW: ASR ══════ -->
    <RelativeLayout
        android:id="@+id/row_asr"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/label_asr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/prayer_asr"
            android:textColor="#D1FAE5"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/dot_asr"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_centerInParent="true"
            android:src="@drawable/widget_dot_upcoming" />

        <TextView
            android:id="@+id/time_asr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="15:45"
            android:textColor="#F59E0B"
            android:textSize="14sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FFFFFF12" />

    <!-- ══════ PRAYER ROW: MAGHRIB ══════ -->
    <RelativeLayout
        android:id="@+id/row_maghrib"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/label_maghrib"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/prayer_maghrib"
            android:textColor="#D1FAE5"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/dot_maghrib"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_centerInParent="true"
            android:src="@drawable/widget_dot_active" />

        <TextView
            android:id="@+id/time_maghrib"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="@string/widget_time_default"
            android:textColor="#F59E0B"
            android:textSize="14sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FFFFFF12" />

    <!-- ══════ PRAYER ROW: ISHA ══════ -->
    <RelativeLayout
        android:id="@+id/row_isha"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/label_isha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/prayer_isha"
            android:textColor="#D1FAE5"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/dot_isha"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_centerInParent="true"
            android:src="@drawable/widget_dot_upcoming" />

        <TextView
            android:id="@+id/time_isha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="20:00"
            android:textColor="#F59E0B"
            android:textSize="14sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- Bottom divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FFFFFF20"
        android:layout_marginTop="6dp" />

    <!-- ══════ FOOTER: Location + countdown ══════ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <!-- Location chip -->
        <LinearLayout
            android:id="@+id/widget_location_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_location_chip"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/widget_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_location_default"
                android:textColor="#D1FAE5"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:maxWidth="120dp" />

        </LinearLayout>

        <!-- "Next in X min" -->
        <TextView
            android:id="@+id/widget_time_remaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="@string/widget_time_remaining_default"
            android:textColor="#6EE7B7"
            android:textSize="9sp" />

    </RelativeLayout>

</LinearLayout>
